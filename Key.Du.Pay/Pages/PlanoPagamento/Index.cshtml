@page
@model Key.Du.Pay.UserInterface.Pages.PlanoPagamento.IndexModel
@{
    ViewData["Title"] = "Planos de pagamento";
}
<div class="card shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h1 class="h5 mb-0">Planos de pagamento</h1>
        <a class="btn btn-primary btn-sm" asp-page="Create">Novo plano</a>
    </div>
    <div class="card-body p-0">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success m-3 mb-0">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger m-3 mb-0">@TempData["Error"]</div>
        }
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Id</th>
                        <th>Responsável</th>
                        <th>Centro de custo</th>
                        <th class="text-end">Valor total</th>
                        <th class="text-end">Cancelado</th>
                        <th>Cobranças</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Itens)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.ResponsavelFinanceiro.Descricao</td>
                            <td>@item.CentroCusto.Descricao</td>
                            <td class="text-end fw-bold">@item.ValorTotal.ToString("C", new System.Globalization.CultureInfo("pt-BR"))</td>
                            <td class="text-end text-danger opacity-75">@item.ValorTotalCancelado.ToString("C", new System.Globalization.CultureInfo("pt-BR"))</td>
                            <td>@(item.CobrancaEntities?.Count ?? 0)</td>
                            <td class="text-end">
                                <a class="btn btn-outline-secondary btn-sm" asp-page="Edit" asp-route-id="@item.Id">Editar</a>
                                <a class="btn btn-outline-danger btn-sm" asp-page="Delete" asp-route-id="@item.Id">Excluir</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
