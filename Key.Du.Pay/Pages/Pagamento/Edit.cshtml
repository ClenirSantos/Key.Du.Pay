@page "{id:int}"
@model Key.Du.Pay.UserInterface.Pages.Pagamento.EditModel
@{
    ViewData["Title"] = "Editar pagamento";
}
<div class="card shadow-sm" style="max-width: 480px;">
    <div class="card-header bg-white">
        <h1 class="h5 mb-0">Editar pagamento</h1>
    </div>
    <div class="card-body">
        <form method="post">
            <input type="hidden" asp-for="Input.Id" />
            <input type="hidden" asp-for="Input.CobrancaID" />
            <div asp-validation-summary="All" class="text-danger"></div>
            <p class="text-muted">Cobrança: <strong>#@Model.Input.CobrancaID</strong></p>
            <div class="mb-3">
                <label class="form-label" asp-for="Input.Valor"></label>
                <input class="form-control" asp-for="Input.Valor" type="number" step="0.01" min="0" />
            </div>
            <div class="mb-3">
                <label class="form-label" asp-for="Input.DataPagamento"></label>
                <input class="form-control" asp-for="Input.DataPagamento" type="datetime-local" />
            </div>
            <button type="submit" class="btn btn-primary">Salvar</button>
            <a class="btn btn-outline-secondary" asp-page="Index">Cancelar</a>
        </form>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
