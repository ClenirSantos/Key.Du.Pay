@page
@model Key.Du.Pay.UserInterface.Pages.Cobranca.CreateModel
@{
    ViewData["Title"] = "Nova cobrança";
}
<div class="card shadow-sm" style="max-width: 560px;">
    <div class="card-header bg-white">
        <h1 class="h5 mb-0">Nova cobrança</h1>
    </div>
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="mb-3">
                <label class="form-label" asp-for="Input.PlanoPagamentoID"></label>
                <select class="form-select" asp-for="Input.PlanoPagamentoID" asp-items="Model.Planos"></select>
            </div>
            <div class="mb-3">
                <label class="form-label" asp-for="Input.Descricao"></label>
                <input class="form-control" asp-for="Input.Descricao" />
            </div>
            <div class="mb-3">
                <label class="form-label" asp-for="Input.Valor"></label>
                <input class="form-control" asp-for="Input.Valor" type="number" step="0.01" min="0" />
            </div>
            <div class="mb-3">
                <label class="form-label" asp-for="Input.DataVencimento"></label>
                <input class="form-control" asp-for="Input.DataVencimento" type="date" />
            </div>
            <div class="mb-3">
                <label class="form-label" asp-for="Input.MetodoPagamento"></label>
                <select class="form-select" asp-for="Input.MetodoPagamento" asp-items="Html.GetEnumSelectList<EnumMetodoPagamento>()"></select>
            </div>
            <button type="submit" class="btn btn-primary">Salvar</button>
            <a class="btn btn-outline-secondary" asp-page="Index">Cancelar</a>
        </form>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
