@page
@model Key.Du.Pay.UserInterface.Pages.ResponsavelFinanceiro.CreateModel
@{
    ViewData["Title"] = "Novo responsável";
}
<div class="card shadow-sm" style="max-width: 640px;">
    <div class="card-header bg-white">
        <h1 class="h5 mb-0">Novo responsável financeiro</h1>
    </div>
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="mb-3">
                <label class="form-label" asp-for="Input.Descricao"></label>
                <input class="form-control" asp-for="Input.Descricao" />
            </div>
            <div class="mb-3">
                <label class="form-label" asp-for="Input.Adimplente"></label>
                <select class="form-select" asp-for="Input.Adimplente" asp-items="Html.GetEnumSelectList<EnumAdimplencia>()"></select>
            </div>
            <div class="mb-3">
                <label class="form-label" asp-for="Input.TipoUsuario"></label>
                <select class="form-select" asp-for="Input.TipoUsuario" asp-items="Html.GetEnumSelectList<EnumTipoUsuario>()"></select>
            </div>
            <button type="submit" class="btn btn-primary">Salvar</button>
            <a class="btn btn-outline-secondary" asp-page="Index">Cancelar</a>
        </form>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
